{
  "name": "equipment-telemetry-db",
  "version": "1.0.0",
  "private": true,
  "description": "Knex migrations and seeds for equipment-telemetry-demo",
  "scripts": {
    "migrate": "knex --knexfile knexfile.ts migrate:latest",
    "migrate:rollback": "knex --knexfile knexfile.ts migrate:rollback",
    "migrate:status": "knex --knexfile knexfile.ts migrate:status",
    "seed": "knex --knexfile knexfile.ts seed:run"
  },
  "dependencies": {
    "knex": "^3.1.0",
    "pg": "^8.13.0"
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  }
}
